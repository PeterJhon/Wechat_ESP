/* pages/dither/dither.wxss */
.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.header {
  text-align: center;
  margin-bottom: 30rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.subtitle {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 控制面板 */
.control-panel {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.dither-selector {
  margin: 20rpx 0;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.picker {
  width: 100%;
}

.picker-text {
  font-size: 30rpx;
  color: #333;
  padding: 16rpx;
  background: #f8f8f8;
  border-radius: 8rpx;
}

.picker-desc {
  font-size: 24rpx;
  color: #999;
}

.row {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

/* 按钮 */
.btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.btn-secondary {
  flex: 1;
  background: #f0f0f0;
  color: #666;
}

.btn-process {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: #fff;
}

.btn-save {
  width: auto;
  padding: 0 40rpx;
  background: #4caf50;
  color: #fff;
}

/* 增强参数面板 */
.enhance-panel {
  background: #fff;
  border-radius: 16rpx;
  padding: 0;
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease;
}

.enhance-panel.show {
  padding: 24rpx;
  max-height: 1000rpx;
}

.param-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.param-label {
  width: 120rpx;
  font-size: 26rpx;
  color: #666;
}

.slider {
  flex: 1;
  margin: 0 20rpx;
}

.param-value {
  width: 80rpx;
  text-align: right;
  font-size: 26rpx;
  color: #333;
}

/* 图片预览 */
.preview-area {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.image-container {
  position: relative;
}

.image-label {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.preview-image {
  width: 100%;
  height: 400rpx;
  border-radius: 12rpx;
  background: #f8f8f8;
}

/* 颜色统计 */
.color-stats {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.stats-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.color-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.color-item {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
  background: #f8f8f8;
  border-radius: 20rpx;
}

.color-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  margin-right: 8rpx;
  border: 1rpx solid #ddd;
}

.color-name {
  font-size: 24rpx;
  color: #666;
  margin-right: 8rpx;
}

.color-percent {
  font-size: 24rpx;
  color: #999;
}

/* 调色板 */
.palette {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.palette-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.palette-colors {
  display: flex;
  justify-content: space-between;
}

.palette-color {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid #eee;
}

.color-label {
  font-size: 20rpx;
  color: #333;
  font-weight: bold;
}
