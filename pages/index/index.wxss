/* pages/index/index.wxss */
.container {
  padding: 20rpx;
  min-height: 100vh;
  background: #f5f5f5;
}

.header {
  text-align: center;
  margin-bottom: 20rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 15rpx;
}

.status {
  font-size: 24rpx;
  color: #999;
}

.status.success {
  color: #07c160;
}

/* 标签页 */
.tabs {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  border-bottom: 4rpx solid transparent;
  transition: all 0.3s;
}

.tab.active {
  color: #07c160;
  border-bottom-color: #07c160;
  font-weight: bold;
}

.tab-content {
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.actions {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.actions .action-btn {
  width: 200rpx;
  font-size: 28rpx;
}

.searching {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 15rpx;
  padding: 20rpx;
  background: #fff;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
}

.loading {
  width: 30rpx;
  height: 30rpx;
  border: 3rpx solid #ddd;
  border-top-color: #07c160;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.list-title {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 15rpx;
}

.device-list {
  background: #fff;
  border-radius: 10rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.scroll-area {
  max-height: 600rpx;
}

.device-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 25rpx;
  background: #f9f9f9;
  border-radius: 8rpx;
  margin-bottom: 15rpx;
  transition: all 0.3s;
}

.device-item:last-child {
  margin-bottom: 0;
}

.device-item.active {
  background: #e8f8ef;
  border: 2rpx solid #07c160;
}

.device-info {
  flex: 1;
}

.device-name {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.device-id {
  display: block;
  font-size: 22rpx;
  color: #999;
}

.device-rssi {
  font-size: 24rpx;
  color: #666;
  margin-right: 20rpx;
}

.device-status {
  font-size: 26rpx;
  color: #07c160;
  padding: 10rpx 20rpx;
  background: #fff;
  border-radius: 20rpx;
  border: 1rpx solid #07c160;
}

.empty {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
}

.services {
  background: #fff;
  border-radius: 10rpx;
  padding: 20rpx;
}

.service-item {
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 8rpx;
  margin-bottom: 10rpx;
}

.service-uuid {
  display: block;
  font-size: 26rpx;
  color: #333;
  margin-bottom: 5rpx;
}

.service-char {
  font-size: 24rpx;
  color: #999;
}

/* 图片处理相关 */
.image-section {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.btn-choose {
  width: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.btn-crop {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
  color: #fff;
  font-size: 28rpx;
  margin-top: 15rpx;
}

/* 尺寸选��器 */
.crop-size-selector {
  display: flex;
  gap: 15rpx;
  margin-top: 15rpx;
}

.size-option {
  flex: 1;
  padding: 15rpx;
  background: #f5f5f5;
  border-radius: 10rpx;
  text-align: center;
  border: 2rpx solid transparent;
}

.size-option.active {
  background: #e8f8ef;
  border-color: #07c160;
}

.size-name {
  display: block;
  font-size: 24rpx;
  color: #333;
  margin-bottom: 4rpx;
}

.size-value {
  display: block;
  font-size: 20rpx;
  color: #999;
}

.size-option.active .size-value {
  color: #07c160;
}

.preview-box {
  margin-top: 20rpx;
}

.preview-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.preview-img {
  width: 100%;
  height: 400rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
}

/* 抖动算法选择 */
.dither-section {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
}

.toggle-btn {
  font-size: 24rpx;
  color: #667eea;
  font-weight: normal;
}

.algorithm-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.algo-item {
  flex: 1;
  min-width: 140rpx;
  padding: 16rpx 12rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  text-align: center;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.algo-item.active {
  background: #e8f0ff;
  border-color: #667eea;
}

.algo-name {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 4rpx;
}

.algo-desc {
  display: block;
  font-size: 20rpx;
  color: #999;
}

/* 增强参数面板 */
.enhance-panel {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease;
}

.enhance-panel.show {
  max-height: 500rpx;
  margin-bottom: 20rpx;
}

.param-row {
  display: flex;
  align-items: center;
  margin-bottom: 15rpx;
}

.param-label {
  width: 150rpx;
  font-size: 24rpx;
  color: #666;
}

.param-slider {
  flex: 1;
}

.btn-reset {
  width: 100%;
  height: 60rpx;
  line-height: 60rpx;
  font-size: 26rpx;
  background: #f0f0f0;
  color: #666;
  margin-top: 10rpx;
}

.btn-process {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: #fff;
  font-size: 30rpx;
  margin-bottom: 20rpx;
}

/* 处理结果 */
.result-box {
  margin-top: 20rpx;
}

.result-actions {
  display: flex;
  gap: 15rpx;
  margin-top: 15rpx;
}

.btn-action {
  flex: 1;
  height: 70rpx;
  line-height: 70rpx;
  font-size: 28rpx;
  background: #f0f0f0;
  color: #333;
}

.btn-send {
  background: #07c160;
  color: #fff;
}

/* 调色板展示 */
.palette-section {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
}

.palette-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 15rpx;
}

.palette-stat-item {
  flex: 1;
  min-width: 140rpx;
  padding: 12rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.color-preview {
  width: 50rpx;
  height: 50rpx;
  border-radius: 8rpx;
  border: 1rpx solid #ddd;
}

.color-name {
  font-size: 24rpx;
  color: #333;
}

.color-percent {
  font-size: 22rpx;
  color: #999;
}

.color-hint {
  font-size: 24rpx;
  color: #999;
  width: 100%;
  text-align: center;
}
