/**app.wxss**/
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif;
}

button {
  border-radius: 8rpx;
}

button[type="primary"] {
  background-color: #07c160;
}

button[type="warn"] {
  background-color: #fa5151;
}
